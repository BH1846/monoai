# MONOAI_GATEWAY_URL: base URL of the running MonoAI gateway (gateway/app.py).
# Overridable per-request from the browser via the Settings panel (stored in
# sessionStorage, sent as the x-monoai-gateway-url header to this server).
MONOAI_GATEWAY_URL=http://localhost:8000

# MONOAI_ADMIN_KEY: fallback admin bearer used for /api/admin/* passthrough
# when the browser doesn't supply an x-monoai-admin-key header. Must match
# the gateway's own MONOAI_ADMIN_KEY. Optional -- normally pasted into the
# Settings panel instead and kept in sessionStorage only.
MONOAI_ADMIN_KEY=

# MONOAI_VIRTUAL_KEY: fallback virtual key used for /api/chat when the
# browser doesn't supply an x-monoai-virtual-key header. Optional -- normally
# created via the Users tab and pasted into Settings instead.
MONOAI_VIRTUAL_KEY=
