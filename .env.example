# Copy this file to .env and fill in real values. Never commit .env.

# --- Vault / Valkey (hard dependency; no on-disk fallback) ---
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6380
VALKEY_PASSWORD=change-me-generate-a-real-secret
VALKEY_KEY_NAME=sentinel:pii_vault:master_key

# --- Session token determinism (G8) ---
# Single per-deployment secret used to derive per-session HMAC keys for
# core/vault/session_tokens.py. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_TOKEN_SECRET=change-me-generate-a-real-secret

# --- Gateway ---
PII_VAULT_STORAGE_PATH=./pii_vault.sqlite
PII_USE_ONNX_NER=true
MONOAI_AUDIT_LOG_PATH=./gateway_audit.jsonl
MONOAI_ADMIN_KEY=change-me-generate-a-real-secret
GATEWAY_KEY_STORE_PATH=./gateway_keys.sqlite
POLICY_DIR=./policies

# --- Provider selection: stub (default, no external calls) | ollama | cloud ---
MONOAI_PROVIDER=stub
OLLAMA_BASE_URL=http://localhost:11434

# --- Cloud provider (any OpenAI-compatible API: Groq/OpenAI/OpenRouter/Together/...) ---
CLOUD_API_BASE_URL=https://api.groq.com/openai/v1
CLOUD_PROVIDER_NAME=groq
CLOUD_API_KEY=your-key-here
CLOUD_MODEL_SIMPLE=llama-3.1-8b-instant
CLOUD_MODEL_MODERATE=llama-3.3-70b-versatile
CLOUD_MODEL_COMPLEX=qwen/qwen3-32b
# Optional per-tier keys/fallbacks — see gateway/config.py
# CLOUD_API_KEY_SIMPLE=
# CLOUD_API_KEY_MODERATE=
# CLOUD_API_KEY_COMPLEX=
