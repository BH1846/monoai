# Copy this file to .env and fill in real values. Never commit .env.

# --- Vault / Valkey (hard dependency; no on-disk fallback) ---
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6380
VALKEY_PASSWORD=change-me-generate-a-real-secret
VALKEY_KEY_NAME=sentinel:pii_vault:master_key

# --- Session token determinism (G8) ---
# Single per-deployment secret used to derive per-session HMAC keys for
# core/vault/session_tokens.py. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_TOKEN_SECRET=change-me-generate-a-real-secret

# --- Gateway ---
PII_VAULT_STORAGE_PATH=./pii_vault.sqlite
PII_USE_ONNX_NER=true
MONOAI_AUDIT_LOG_PATH=./gateway_audit.jsonl
MONOAI_ADMIN_KEY=change-me-generate-a-real-secret
GATEWAY_KEY_STORE_PATH=./gateway_keys.sqlite
POLICY_DIR=./policies
# Runtime provider/model registry (gateway/providers/registry_store.py) --
# admin-registered upstream credentials, encrypted at rest via the vault.
PROVIDER_STORE_PATH=./gateway_providers.sqlite

# --- Postgres backends (Phase 4): sqlite (default) | postgres ---
VAULT_BACKEND=sqlite
VAULT_POSTGRES_DSN=postgresql://monoai:change-me@127.0.0.1:5433/monoai
KEY_STORE_BACKEND=sqlite
KEY_STORE_POSTGRES_DSN=postgresql://monoai:change-me@127.0.0.1:5433/monoai

# --- Audit sink: jsonl (default) | postgres | webhook ---
AUDIT_SINK=jsonl
AUDIT_POSTGRES_DSN=
AUDIT_WEBHOOK_URL=
# G13: per-record Ed25519 signing. Key derives from AUDIT_SIGN_KEY, or
# falls back to SESSION_TOKEN_SECRET if unset.
MONOAI_AUDIT_SIGN=false
MONOAI_AUDIT_SIGN_KEY=

# --- G4: Tier 2.5 semantic injection judge (Ollama first, Claude API fallback) ---
MONOAI_ENABLE_LLM_JUDGE=false
MONOAI_LLM_JUDGE_MODEL=qwen2.5:7b
MONOAI_LLM_JUDGE_CLAUDE_API_KEY=
MONOAI_LLM_JUDGE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- G9: OTEL trace/metric export -- degrades to console output if unset ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=monoai-gateway

# --- MCP tool firewall (mcp-firewall/) ---
MCP_TOOL_RULES_PATH=./mcp-firewall/tool_rules.yaml
MCP_UPSTREAM_URL=http://localhost:9000

# --- Provider selection: stub (default, no external calls) | ollama | cloud ---
MONOAI_PROVIDER=stub
OLLAMA_BASE_URL=http://localhost:11434

# --- Cloud provider (any OpenAI-compatible API: Groq/OpenAI/OpenRouter/Together/...) ---
CLOUD_API_BASE_URL=https://api.groq.com/openai/v1
CLOUD_PROVIDER_NAME=groq
CLOUD_API_KEY=your-key-here
CLOUD_MODEL_SIMPLE=llama-3.1-8b-instant
CLOUD_MODEL_MODERATE=llama-3.3-70b-versatile
CLOUD_MODEL_COMPLEX=qwen/qwen3-32b
# Optional per-tier keys/fallbacks — see gateway/config.py
# CLOUD_API_KEY_SIMPLE=
# CLOUD_API_KEY_MODERATE=
# CLOUD_API_KEY_COMPLEX=
