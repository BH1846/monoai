# SENTINEL agent — copy to agent/.env on the agent host and fill in.
# NOTE: intentionally NO Valkey / vault / manager-DB settings here. The agent
# holds only its own private key + the manager's public key (see README).

MANAGER_URL=http://127.0.0.1:8000
# One-time enrollment token from the manager admin
# (`POST /v1/admin/agents/enroll-token`). Needed on first run only.
AGENT_ENROLL_TOKEN=
AGENT_POLICY_ID=default
# AGENT_HOSTNAME defaults to the machine's nodename if unset.
# AGENT_HOSTNAME=edge-1
AGENT_STATE_DIR=./agent_state

# Detection
PII_USE_ONNX_NER=true

# Daemon intervals (seconds)
AGENT_SYNC_INTERVAL_S=10
AGENT_POLICY_POLL_INTERVAL_S=60
AGENT_HEARTBEAT_INTERVAL_S=30
AGENT_INGEST_BATCH_SIZE=200
